GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_GENAI_USE_VERTEXAI=True
ENABLE_GEMINI_SYNTHESIS=true
GEMINI_MODEL=gemini-2.5-flash

PHOENIX_PROJECT_NAME=traceguard-hackathon
PHOENIX_BASE_URL=https://app.phoenix.arize.com
PHOENIX_COLLECTOR_ENDPOINT=https://app.phoenix.arize.com/s/your-space-name
# Optional: TraceGuard derives api_key=<PHOENIX_API_KEY> automatically when this is absent.
# PHOENIX_CLIENT_HEADERS=api_key=your-phoenix-api-key
PHOENIX_MCP_SERVER=@arizeai/phoenix-mcp
# Optional: enables live read-only MCP initialize, tools/list, list-projects, and list-traces introspection.
# Prefer PHOENIX_API_KEY / PHOENIX_BASE_URL environment variables over putting secrets in command args.
# Cloud Run image preinstalls @arizeai/phoenix-mcp@4.0.13, so phoenix-mcp is preferred there.
# PHOENIX_MCP_COMMAND=phoenix-mcp
# PHOENIX_MCP_TIMEOUT_SECONDS=12
# PHOENIX_API_KEY belongs in Secret Manager for Cloud Run, not in this file.

# Optional locally; required for the hosted demo. Store this in Secret Manager on Cloud Run.
# TRACEGUARD_AUTH_TOKEN=use-a-long-random-access-key
# TRACEGUARD_AUTH_SESSION_SECONDS=43200
